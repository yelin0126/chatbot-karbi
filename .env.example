# ══════════════════════════════════════════════════════════════════════
# Tilron AI Chatbot — Environment Configuration
# Copy this file to .env and modify as needed
# ══════════════════════════════════════════════════════════════════════

# ── Ollama / LLM ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=qwen2.5:7b
AVAILABLE_MODELS=qwen2.5:7b,llama3.1:latest,llama3.2-vision:11b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=180

# ── Embedding ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DEVICE=cuda    # auto-detected if not set

# ── Reranker (optional — improves retrieval accuracy) ─────────────────
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=3

# ── Retrieval ─────────────────────────────────────────────────────────
VECTOR_TOP_K=4

# ── Chunking ──────────────────────────────────────────────────────────
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# ── Paths ─────────────────────────────────────────────────────────────
# DATA_DIR=./data
# CHROMA_DIR=./chroma_db

# ── Features ──────────────────────────────────────────────────────────
ENABLE_OCR=true
AUTO_INGEST_ON_STARTUP=false

# ── Web Search ────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO