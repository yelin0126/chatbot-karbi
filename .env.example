# ══════════════════════════════════════════════════════════════════════
# Tilon AI Chatbot — Environment Configuration
# Copy this file to .env and modify as needed
# ══════════════════════════════════════════════════════════════════════

# ── Ollama / LLM ──────────────────────────────────────────────────────
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_MODEL=qwen2.5:7b
AVAILABLE_MODELS=qwen2.5:7b,qwen2.5vl:7b,llama3.1:latest,mistral:7b
LOCAL_LLM_MODEL_NAME=qwen25-qlora-v9
LOCAL_LLM_ADAPTER_PATH=./finetuning/output/qwen25-qlora-v9
# LOCAL_LLM_BASE_MODEL=Qwen/Qwen2.5-7B-Instruct
LOCAL_LLM_LOCAL_FILES_ONLY=true
LOCAL_LLM_LOAD_IN_4BIT=true
# LOCAL_LLM_DEVICE=cuda
LOCAL_LLM_MAX_INPUT_TOKENS=4096
LOCAL_LLM_OOM_RETRY_INPUT_TOKENS=3072
LOCAL_LLM_OOM_RETRY_MAX_TOKENS=512
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=180

# ── Embedding ─────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
# EMBEDDING_DEVICE=cuda    # set explicitly on GPU machines; auto-detected if omitted

# ── Reranker (optional — improves retrieval accuracy) ─────────────────
RERANKER_ENABLED=false
LIVE_RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=3
RERANKER_DEVICE=cpu
RERANKER_USE_FP16=true

# ── Retrieval ─────────────────────────────────────────────────────────
VECTOR_TOP_K=6
GLOBAL_MIN_RELEVANCE_SCORE=0.30
DOCUMENT_CONFIDENCE_THRESHOLD=0.45
SCOPED_SINGLE_CHUNK_CONFIDENCE_THRESHOLD=0.30
STRONG_KEYWORD_CONFIDENCE_FLOOR=0.75
SCOPED_SMALL_DOC_FULL_CONTEXT_MAX_CHUNKS=15

# ── Chunking ──────────────────────────────────────────────────────────
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# ── Paths ─────────────────────────────────────────────────────────────
# DATA_DIR=./data
# LIBRARY_DIR=./data/library
# UPLOADS_DIR=./data/uploads
# TEMP_DIR=./data/temp
# CHROMA_DIR=./chroma_db

# ── Features ──────────────────────────────────────────────────────────
ENABLE_OCR=true
AUTO_INGEST_ON_STARTUP=false

# ── VLM PDF Extraction ────────────────────────────────────────────────
VLM_EXTRACTION_ENABLED=true
VLM_SCANNED_PDF_ENABLED=true
VLM_HYBRID_PDF_ENABLED=false
VLM_EXTRACTION_MODEL=qwen2.5vl:7b

# ── Web Search ────────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
